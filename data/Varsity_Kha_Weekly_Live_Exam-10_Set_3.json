        "solution_html": "<p><span class=\"english\">অর্থগতভাবে</span><span> </span><span class=\"english\">বাংলা</span><span> </span><span class=\"english\">শব্দকে</span><span> </span><span class=\"english\">তিনভাগে</span><span> </span><span class=\"english\">ভাগ</span><span> </span><span class=\"english\">করা</span><span> </span><span class=\"english\">হয়েছে</span><span class=\"english\">। </span></p><p><span class=\"english\">(i)</span><span> </span><span><span> </span></span><span class=\"english\">যৌগিক</span><span> </span><span class=\"english\">শব্দ</span><span class=\"english\">:</span><span> </span><span class=\"english\">যে</span><span> </span><span class=\"english\">সকল</span><span> </span><span class=\"english\">শব্দের</span><span> </span><span class=\"english\">ব্যুৎপত্তিগত</span><span class=\"english\"> (</span><span class=\"english\">উৎপত্তি</span><span class=\"english\">) </span><span class=\"english\">অর্থ</span><span> </span><span class=\"english\">ও</span><span> </span><span class=\"english\">ব্যাবহারিক</span><span class=\"english\"> (</span><span class=\"english\">প্রচলিত</span><span class=\"english\">) </span><span class=\"english\">অর্থ</span><span> </span><span class=\"english\">একই</span><span> </span><span class=\"english\">রকম</span><span class=\"english\">, </span><span class=\"english\">সেগুলোকে</span><span> </span><span class=\"english\">যৌগিক</span><span> </span><span class=\"english\">শব্দ</span><span> </span><span class=\"english\">বলে</span><span class=\"english\">। </span><span class=\"english\">যেমন</span><span class=\"english\">: </span><span class=\"english\">কর্তব্য</span><span class=\"english\">,</span><span> </span><span class=\"english\">পক্ষী</span><span> </span><span class=\"english\">ইত্যাদি</span><span class=\"english\">। </span></p><p><span class=\"english\">(ii)</span><span> </span><span><span> </span></span><span class=\"english\">রূঢ়ি</span><span> </span><span class=\"english\">শব্দ</span><span class=\"english\">/</sp