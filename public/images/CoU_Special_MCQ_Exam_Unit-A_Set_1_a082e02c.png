                                    </div>
                                            <div class="col-sm-12 row questionOption">
                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">C</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000c98eac08-a041-4bde-ba36-e557e54b53f4" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(\frac{1}{2\sqrt{2}}\) </span><span xml:space="preserve" class="pt-000001c98eac08-a041-4bde-ba36-e557e54b53f4"> </span><style>span { white-space: pre-wrap; }p.pt-000000c98eac08-a041-4bde-ba36-e557e54b53f4 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001c98eac08-a041-4bde-ba36-e557e54b53f4 {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
