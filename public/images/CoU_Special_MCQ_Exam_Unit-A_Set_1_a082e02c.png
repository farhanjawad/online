                                            <div class="col-sm-12 row questionOption">
                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text" style="font-weight:bold;">D</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-0000006f597d61-bf3c-4d4f-8c6f-9d4badd14e1f" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(2\sqrt{2}\) </span><span xml:space="preserve" class="pt-0000016f597d61-bf3c-4d4f-8c6f-9d4badd14e1f"> </span><style>span { white-space: pre-wrap; }p.pt-0000006f597d61-bf3c-4d4f-8c6f-9d4badd14e1f {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-0000016f597d61-bf3c-4d4f-8c6f-9d4badd14e1f {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
