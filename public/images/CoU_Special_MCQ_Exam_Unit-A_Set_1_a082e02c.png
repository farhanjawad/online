                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text" style="font-weight:bold;">D</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000ce77b178-86ed-4020-98f4-68ea7c25d33f" xmlns="http://www.w3.org/1999/xhtml"><span class="pt-000001ce77b178-86ed-4020-98f4-68ea7c25d33f">35/3 sq units</span><style>span { white-space: pre-wrap; }p.pt-000000ce77b178-86ed-4020-98f4-68ea7c25d33f {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001ce77b178-86ed-4020-98f4-68ea7c25d33f {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
