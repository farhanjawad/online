                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">C</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000d14d3690-e4d5-40b0-b568-9bc0af727590" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(\frac{1}{2{e}^{2x}}+c\) </span><span xml:space="preserve" class="pt-000001d14d3690-e4d5-40b0-b568-9bc0af727590"> </span><style>span { white-space: pre-wrap; }p.pt-000000d14d3690-e4d5-40b0-b568-9bc0af727590 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001d14d3690-e4d5-40b0-b568-9bc0af727590 {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
