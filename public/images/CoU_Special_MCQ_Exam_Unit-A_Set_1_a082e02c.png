                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000ae155d30-76a6-4c47-ab21-f4bba05d269f" xmlns="http://www.w3.org/1999/xhtml"><span class="pt-000001ae155d30-76a6-4c47-ab21-f4bba05d269f">8/3 sq units</span><style>span { white-space: pre-wrap; }p.pt-000000ae155d30-76a6-4c47-ab21-f4bba05d269f {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001ae155d30-76a6-4c47-ab21-f4bba05d269f {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
