                                            <div class="col-sm-12 row questionOption">
                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text" style="font-weight:bold;">D</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000ba13fdd8-f800-4a2d-a93f-f89d59c4a01a" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(\frac{-1}{2{e}^{2x}}+c\) </span><span xml:space="preserve" class="pt-000001ba13fdd8-f800-4a2d-a93f-f89d59c4a01a"> </span><style>span { white-space: pre-wrap; }p.pt-000000ba13fdd8-f800-4a2d-a93f-f89d59c4a01a {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001ba13fdd8-f800-4a2d-a93f-f89d59c4a01a {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
