                                        <div class="input-group" style="align-items: center;">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">A</span>
                                            </div>
                                            <div class="input-group-append questionTable">
                                                <label style="margin-left:5px;"><p class="pt-0000002c3ee498-8e9b-42dd-9566-da26d08f9efc" xmlns="http://www.w3.org/1999/xhtml"><span class="pt-0000012c3ee498-8e9b-42dd-9566-da26d08f9efc">26/3 sq units</span><style>span { white-space: pre-wrap; }p.pt-0000002c3ee498-8e9b-42dd-9566-da26d08f9efc {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-0000012c3ee498-8e9b-42dd-9566-da26d08f9efc {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
