                                                <label style="margin-left:5px;"><p class="pt-0000004478c28d-90fc-4d86-aed1-373980af5449" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(\frac{1}{\sqrt{2}}\) </span><span xml:space="preserve" class="pt-0000014478c28d-90fc-4d86-aed1-373980af5449"> </span><style>span { white-space: pre-wrap; }p.pt-0000004478c28d-90fc-4d86-aed1-373980af5449 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-0000014478c28d-90fc-4d86-aed1-373980af5449 {font-family: SutonnyMJ;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                <span class='fas fa-check'></span>
