                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-0000007085e336-5b98-401d-9dc7-d3a508032620" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(ln\ {\left| tanx\right| }+c\) </span><span xml:space="preserve" class="pt-0000017085e336-5b98-401d-9dc7-d3a508032620"> </span><style>span { white-space: pre-wrap; }p.pt-0000007085e336-5b98-401d-9dc7-d3a508032620 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-0000017085e336-5b98-401d-9dc7-d3a508032620 {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
