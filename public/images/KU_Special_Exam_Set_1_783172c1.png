                                                <div class="input-group" style="align-items: center;">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text" style="font-weight:bold;">D</span>
                                                    </div>
                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000d6ce9e37-54e0-4d39-bc65-f689000f76e5" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(1\) </span><span xml:space="preserve" class="pt-000001d6ce9e37-54e0-4d39-bc65-f689000f76e5"> </span><style>span { white-space: pre-wrap; }p.pt-000000d6ce9e37-54e0-4d39-bc65-f689000f76e5 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001d6ce9e37-54e0-4d39-bc65-f689000f76e5 {font-family: Times New Roman;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
