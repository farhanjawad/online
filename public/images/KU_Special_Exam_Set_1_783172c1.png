                                                    <div class="input-group-append questionTable">
                                                        <label style="margin-left:5px;"><p class="pt-000000078bdd5f-f40f-45a0-9a46-03abb2c8d1e0" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(-2\) </span><span xml:space="preserve" class="pt-000001078bdd5f-f40f-45a0-9a46-03abb2c8d1e0"> </span><style>span { white-space: pre-wrap; }p.pt-000000078bdd5f-f40f-45a0-9a46-03abb2c8d1e0 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001078bdd5f-f40f-45a0-9a46-03abb2c8d1e0 {font-family: Times New Roman;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                        
