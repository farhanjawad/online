                                                <label style="margin-left:5px;"><p class="pt-00000079ec358a-7eb4-4fff-97fb-48a270c0ffa2" xmlns="http://www.w3.org/1999/xhtml"><span class="math-tex" style="font-family: Cambria Math !important;" xmlns="">\(\sqrt{\frac{13}{2}}(1+2i)\) </span><span xml:space="preserve" class="pt-00000179ec358a-7eb4-4fff-97fb-48a270c0ffa2"> </span><style>span { white-space: pre-wrap; }p.pt-00000079ec358a-7eb4-4fff-97fb-48a270c0ffa2 {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-00000179ec358a-7eb4-4fff-97fb-48a270c0ffa2 {font-family: Cambria Math;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                
