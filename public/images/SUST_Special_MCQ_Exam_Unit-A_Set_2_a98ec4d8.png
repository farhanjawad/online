                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-sm-12 row questionOption">
                                        <div class="input-group" style="align-items: center;">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">B</span>
                                            </div>
                                            <div class="input-group-append questionTable">
                                                <label style="margin-left:5px;"><p class="pt-000000a48ee691-ccc8-4356-861f-05ee9738093d" xmlns="http://www.w3.org/1999/xhtml"><span class="pt-000001a48ee691-ccc8-4356-861f-05ee9738093d">listening</span><style>span { white-space: pre-wrap; }p.pt-000000a48ee691-ccc8-4356-861f-05ee9738093d {line-height: 108%;margin-top: 0;margin-left: 0;margin-right: 0;margin-bottom: 0;}span.pt-000001a48ee691-ccc8-4356-861f-05ee9738093d {font-family: Times New Roman;color: black;font-style: normal;font-weight: normal;margin: 0;padding: 0;}</style></p></label>
                                                
