<script type="text/javascript">
    $(document).ajaxComplete(function (xhr, status) {
        if (status.getResponseHeader("X-Responded-JSON") != null) {
            var obj = jQuery.parseJSON(status.getResponseHeader("X-Responded-JSON"));
            if (obj.status == 401) {
                //window.location.assign(obj.headers['location']);
                window.location.assign(obj.headers['location'].substr(0, obj.headers['location'].indexOf('?')));
            }
        }
    });

    function mobileCheck(mobileNumber) {
        mobileNumber = mobileNumber.replace(/\W+/g, "");
        var chkVal = mobileNumber.match(/^(?:\+?88)?0?1[13-9]\d{8}$/);
        if (chkVal != null) {
            if (mobileNumber.length == 11) {
                chkVal = '88' + chkVal;
            }
            else if (mobileNumber.length == 10) {
                chkVal = '880' + chkVal;
            }
            var chkVal = mobileNumber.match(/^(?:\+?88)?01[13-9]\d{8}$/);
            if (chkVal != null) {
                if (mobileNumber.length == 11) {
                    chkVal = '88' + chkVal;
                }
                else if (mobileNumber.length == 10) {
                    chkVal = '880' + chkVal;
                }
            }
            //alert(chkVal);
        }
        return chkVal;
    }

    function nickNameCheck(nickName) {
        var chkVal = nickName.match(/^[a-zA-Z .-`]$/);
        return chkVal;
    }

    //This function is used for remove other char without numeric for text field
    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }

    if (!String.prototype.trim) {
        String.prototype.trim = function () {
            return this.replace(/^\s+|\s+$/g, '');
        };
    }

    function showErrorMessageBelowCtrl(ctrlId, message, show) {

        var divHtml = '<div style="color:red;" id="' + ctrlId + '_err_div" >' + message + '</div>';

        if (show == true) {
            $('#' + ctrlId).addClass("highlight");
            $('#' + ctrlId).after(divHtml);
        } else {
            $('#' + ctrlId).removeClass("highlight");
            $('#' + ctrlId + '_err_div').remove();
        }
    }

    function validateTextField(controlId, errorMessage) {

        $(document).on("input propertychange", "#" + controlId, function (event) {

            var value = $("#" + controlId).val().trim();

            if (value.length == 0) {
                showErrorMessageBelowCtrl(controlId, "", false);
                showErrorMessageBelowCtrl(controlId, errorMessage, true);
                return false;
            } else {
                showErrorMessageBelowCtrl(controlId, "", false);
            }
        });
    }

    function validateDropDownField(controlId, targetId, errorMessage) {

        $(document).on("change", "#" + controlId, function (event) {

            var val = $("#" + targetId).val();
            if (val.length == 0) {
                //showErrorMessageBelowCtrl(controlId, "", false);
                showErrorMessageBelowCtrl(controlId, errorMessage, true);
            } else {
                showErrorMessageBelowCtrl(controlId, "", false);
            }
        });
    }

    function validateDropDownField(controlId, errorMessage) {

        $(document).on("change", "#" + controlId, function (event) {

            var val = $("#" + controlId).val();
            if (val.length == 0) {
                showErrorMessageBelowCtrl(controlId, "", false);
                showErrorMessageBelowCtrl(controlId, errorMessage, true);
            } else {
                showErrorMessageBelowCtrl(controlId, "", false);
            }
        });
    }

    function validateListField(controlId, errorMessage) {

        $(document).on("change", "#" + controlId, function (event) {
            var val = $("#" + controlId).val();
            if (val == null || val.length == 0) {
                showErrorMessageBelowCtrl(controlId, "", false);
                showErrorMessageBelowCtrl(controlId, errorMessage, true);
            } else {
                showErrorMessageBelowCtrl(controlId, "", false);
            }
        });
    }

    function scrollToElement(selector) {
        var s = $(selector);
        if (s != undefined)
            $(document.body).scrollTop($(selector).offset().top - 120);
    }

    $(document).ready(function () {

        $("select").change(function () {
            if ($(this).val() != "") {
                $(this).parent().find(".field-validation-error-count").remove();
                $(this).next('span').empty();
            }

            else {
                //$(this).parent().find(".field-validation-error-count").remove();
                $(this).parent().remove("span");
                $(this).parent().append("<span class='text-danger field-validation-error' style='color:red'></span>");
            }
        });

        $(document).on("input propertychange", ".numbersOnly", function (event) {
            var valStr = $(this).val();
            var id = $(this).attr("id");
            var val = parseInt(valStr);
            showErrorMessageBelowCtrl(id, "", false);
            if (isNaN(val)) {
                $(this).val("");
            }
            else if (val < 0) {
                $(this).val("");
                showErrorMessageBelowCtrl(id, "Please enter valid amount", true);
            } else {
                $(this).val(val);
            }
        });
    });
</script>
<script>
    const userAgentGlobal = navigator.userAgent || navigator.vendor || window.opera;
    const isiOS = /iPhone|iPad|iPod/i.test(userAgentGlobal) ||
        (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
    const isAndroid = /Android/i.test(userAgentGlobal);
    const isMacOS = /Macintosh|MacIntel|MacPPC|Mac68K/.test(navigator.platform) && !isiOS;
    const isLinux = /Linux/.test(navigator.platform) && !isiOS && !isAndroid && !isMacOS;
    const isDesktop = !isiOS && !isAndroid && !isMacOS && !isLinux;
    var appApiKeyGlobal = getCookie("appApiKey");
    var studentNameGlobal = getCookie("studentName");
    var userTypeGlobal = 'student';
    var appVersionGlobal = "";
    var returnUrlGlobal = getCookie("AppExamReturnUrl");

    function extractVersion(str) {
        const match = str.match(/\d+(\.\d+)+/);
        return match ? match[0] : null;
    }

    function compareVersions(v1, v2) {
        const parts1 = extractVersion(v1).split('.').map(Number);
        const parts2 = extractVersion(v2).split('.').map(Number);

        for (let i = 0; i < Math.max(parts1.length, parts2.length); i++) {
            const num1 = parts1[i] || 0;
            const num2 = parts2[i] || 0;
            if (num1 < num2) return -1;
            if (num1 > num2) return 1;
        }
        return 0;
    }

    function isVersionGreater(v1, v2) {
        return compareVersions(v1, v2) === 1;
    }

    function isVersionLower(v1, v2) {
        return compareVersions(v1, v2) === -1;
    }

    function isVersionEqual(v1, v2) {
        return compareVersions(v1, v2) === 0;
    }

    function getUserData() {
        return new Promise((resolve, reject) => {
            if (isAndroid) {
                try {
                    const userDataJson = Android.GetUserData();
                    const userData = JSON.parse(userDataJson);
                    resolve(userData);
                } catch (error) {
                    reject("Android GetUserData failed: " + error);
                }
            } else if (isiOS) {
                try {
                    window.receiveGetUserData = function (escapedJsonString) {
                        try {
                            const userData = JSON.parse(escapedJsonString);
                            resolve(userData);
                        } catch (err) {
                            reject("JSON parse error: " + err);
                        }
                    };
                    window.webkit.messageHandlers.GetUserData.postMessage(null);
                } catch (error) {
                    reject("iOS GetUserData call failed: " + error);
                }
            } else {
                reject("Unsupported platform");
            }
        });
    }

    function setUserData(apiKey, regNo, studentName, userType) {
        return new Promise((resolve, reject) => {
            try {
                if (isAndroid) {
                    if ((dataSiteName == 'udvash-unmesh' && isVersionLower(appVersionGlobal, "1.0.8")) || (dataSiteName == 'uttoron' && isVersionLower(appVersionGlobal, "1.0.3"))) {
                        Android.SetUserData(apiKey, regNo, studentName);
                    } else {
                        Android.SetUserData(apiKey, regNo, studentName, userType);
                    }
                    resolve();
                } else if (isiOS) {
                    window.webkit.messageHandlers.SetUserData.postMessage({
                        apiKey: apiKey,
                        regNo: regNo,
                        studentName: studentName,
                        userType: userType
                    });
                    resolve();
                } else {
                    reject("Unsupported platform");
                }
            } catch (error) {
                reject("SetUserData failed: " + error);
            }
        });
    }

    function runOmrFlow() {
        getUserData()
            .then(userData => {
                if (!userData.apiKey || userData.apiKey.trim() === "" || appApiKeyGlobal !== userData.apiKey) {
                    return setUserData(appApiKeyGlobal, appRegistrationNoGlobal, studentNameGlobal, userTypeGlobal);
                }
            })
            .then(() => {
                if (isAndroid) {
                    Android.OmrScan();
                } else if (isiOS) {
                    window.webkit.messageHandlers.OmrScan.postMessage(null);
                }
            })
            .catch(error => {
                console.error("OMR flow failed:", error);
            });
    }

    function runOmrFlowForOnlineOmr() {
        getUserData()
            .then(userData => {
                if (!userData.apiKey || userData.apiKey.trim() === "" || appApiKeyGlobal !== userData.apiKey) {
                    return setUserData(appApiKeyGlobal, appRegistrationNoGlobal, studentNameGlobal, userTypeGlobal);
                }
            })
            .then(() => {
                if (isAndroid) {
                    Android.OmrScanOnline(returnUrlGlobal);
                } else if (isiOS) {
                    window.webkit.messageHandlers.OmrScanOnline.postMessage({
                        returnUrl: returnUrlGlobal
                    });
                }
            })
            .catch(error => {
                console.error("OMR flow failed:", error);
            });
    }


    $(document).ready(function () {
        $('.uuu-left-sidebar ul li').each(function () {
            if (($('#topHeader').attr('data-app-id') == '' && $(this).find('a').attr('href') == '#app') || (isDesktop && $(this).find('a').attr('href') == '#app') || (isMacOS && $(this).find('a').attr('href') == '#app')) {
                $(this).remove();
            }
            else if ($('#topHeader').attr('data-app-id') == '' && $(this).find('a').attr('href') == '#appvideo') {
                $(this).remove();
            }
        });

        if (isMacOS || isLinux) {
            $(document).on('click', 'a[target="_blank"]', function (e) {
                e.preventDefault();

                const url = $(this).attr('href');

                if (url && window.external && typeof window.external.sendMessage === 'function') {
                    window.external.sendMessage(JSON.stringify({
                        MessageType: "OpenNewWindowWithDownload",
                        Payload: { url: url }
                    }));
                }
            });
        }
    });

    $(document).on('click', '.uuu-left-sidebar a, footer .btn-offline-download, .uuu-dashboard-menu .card-body a', function () {
        if ($(this).attr('href') == '#app') {
            if ((dataSiteName == 'udvash-unmesh' && isVersionLower(appVersionGlobal, "1.0.8")) || (dataSiteName == 'uttoron' && isVersionLower(appVersionGlobal, "1.0.3"))) {
                if (isAndroid) {
                    Android.OmrScan();
                } else if (isiOS) {
                    window.webkit.messageHandlers.OmrScan.postMessage(null);
                }
            }
            else {
                runOmrFlow();
            }
        }
        else if ($(this).attr('href') == '#appvideo') {
            if(isAndroid || isiOS){
                if ((dataSiteName == 'udvash-unmesh' && isVersionLower(appVersionGlobal, "1.0.8")) || (dataSiteName == 'uttoron' && isVersionLower(appVersionGlobal, "1.0.3"))) {
                    if (isiOS) {
                        window.webkit.messageHandlers.LaunchOfflineVideo.postMessage(null);
                    }
                    else if (isAndroid) {
                        Android.LaunchOfflineVideo();
                    }
                }
                else {
                    getUserData()
                        .then(userData => {
                            if (!userData.apiKey || userData.apiKey.trim() === "" || appApiKeyGlobal !== userData.apiKey) {
                                return setUserData(appApiKeyGlobal, appRegistrationNoGlobal, studentNameGlobal, userTypeGlobal);
                            }
                        })
                        .then(() => {
                            if (isiOS) {
                                window.webkit.messageHandlers.LaunchOfflineVideo.postMessage(null);
                            }
                            else if (isAndroid) {
                                Android.LaunchOfflineVideo();
                            }
                        })
                        .catch(error => {
                            console.error("flow failed:", error);
                        });
                }
            }
            else{
                if (isDesktop) {
                    if (window.chrome && window.chrome.webview) {
                        window.chrome.webview.postMessage(JSON.stringify({
                            MessageType: "LaunchOfflineVideo",
                            Payload: "abc"
                        }));
                    }
                }
                else if (isMacOS || isLinux) {
                    console.log('Is Mac Or Linux True');
                    if (window.external && typeof window.external.sendMessage === 'function') {
                        window.external.sendMessage(JSON.stringify({
                            MessageType: "LaunchOfflineVideo",
                            Payload: "abc"
                        }));
                    }
                }
            }
        }
    });
</script>
    <script>
        //Disable Inspect Element
        document.onkeydown = function (e) {
            if (event.keyCode == 123) {
                return false;
            }
            if (e.ctrlKey && e.shiftKey && e.keyCode == 'I'.charCodeAt(0)) {
                return false;
            }
            if (e.ctrlKey && e.shiftKey && e.keyCode == 'C'.charCodeAt(0)) {
                return false;
            }
            if (e.ctrlKey && e.shiftKey && e.keyCode == 'J'.charCodeAt(0)) {
                return false;
            }
            if (e.ctrlKey && e.keyCode == 'U'.charCodeAt(0)) {
                return false;
            }
        }

        $(document).bind("contextmenu", function (e) {
            e.preventDefault();
        });
        $(document).keydown(function (e) {
            if (e.which === 123) {
                return false;
            }
        });
    </script>

