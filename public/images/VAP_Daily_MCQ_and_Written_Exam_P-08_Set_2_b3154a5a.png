        $(document).ready(function () {
            let params = new URLSearchParams(window.location.search);
            let type = params.get("sheetType");
            if (type && type === "solvesheet") {
                let questionback = $('.question-back-button').attr('href') + '&sheetType=solvesheet';
                $('.question-back-button').attr('href', questionback);
            } else {
                let questionback = $('.question-back-button').attr('href');
                $('.question-back-button').attr('href', questionback);
            }
        });
    </script>
   
